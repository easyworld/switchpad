<Window x:Class="SwitchPad.Windows.KeyMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="按键映射配置 - Nintendo Switch Pro Controller" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>

        <!-- Circle overlay button style -->
        <Style x:Key="CircleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#B0202020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="1.2"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill overlay button style (L / ZL / R / ZR) -->
        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#B0202020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.2"
                                    CornerRadius="10"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Nintendo Switch Pro Controller" FontSize="22" FontWeight="Bold"
                       Foreground="#1A1A1A" HorizontalAlignment="Center"/>
            <TextBlock Text="点击手柄按键进行键盘映射配置" FontSize="13" Foreground="#666666"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Controller area: SVG + button overlay, scaled uniformly to fill available space -->
        <Viewbox Grid.Row="1" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Fixed 381×265 coordinate space matching SVG viewBox (mm × 10) -->
            <Grid Width="381" Height="265">

                <!-- SVG background -->
                <Border Width="381" Height="265">
                    <Image x:Name="ImageController"
                           Width="381" Height="265"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           IsHitTestVisible="False"/>
                </Border>

                <!-- Button overlay canvas -->
                <Canvas Width="381" Height="265">

                    <!-- ============ SHOULDER BUTTONS ============ -->
                    <!-- L  (cx=75, cy=14) -->
                    <Button x:Name="BtnL" Style="{StaticResource PillButtonStyle}"
                            Width="55" Height="22"
                            Canvas.Left="47.5" Canvas.Top="3"
                            Content="L" FontSize="11" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="L"/>
                    <!-- ZL (cx=38, cy=50) -->
                    <Button x:Name="BtnZL" Style="{StaticResource PillButtonStyle}"
                            Width="44" Height="22"
                            Canvas.Left="16" Canvas.Top="39"
                            Content="ZL" FontSize="11" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="ZL"/>
                    <!-- R  (cx=306, cy=14) -->
                    <Button x:Name="BtnR" Style="{StaticResource PillButtonStyle}"
                            Width="55" Height="22"
                            Canvas.Left="278.5" Canvas.Top="3"
                            Content="R" FontSize="11" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="R"/>
                    <!-- ZR (cx=343, cy=50) -->
                    <Button x:Name="BtnZR" Style="{StaticResource PillButtonStyle}"
                            Width="44" Height="22"
                            Canvas.Left="321" Canvas.Top="39"
                            Content="ZR" FontSize="11" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="ZR"/>

                    <!-- ============ LEFT STICK ============ -->
                    <!-- LStickUp (cx=85.5, cy=50) -->
                    <Button x:Name="BtnLStickUp" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="71.5" Canvas.Top="36"
                            Content="↑" FontSize="13"
                            Click="ButtonMapping_Click" Tag="LStickUp"/>
                    <!-- LStickLeft (cx=55, cy=80) -->
                    <Button x:Name="BtnLStickLeft" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="41" Canvas.Top="66"
                            Content="←" FontSize="13"
                            Click="ButtonMapping_Click" Tag="LStickLeft"/>
                    <!-- L3 center (cx=85.5, cy=80) -->
                    <Button x:Name="BtnLStick" Style="{StaticResource CircleButtonStyle}"
                            Width="46" Height="46"
                            Canvas.Left="62.5" Canvas.Top="57"
                            Content="L3" FontSize="12" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="LStick"/>
                    <!-- LStickRight (cx=116, cy=80) -->
                    <Button x:Name="BtnLStickRight" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="102" Canvas.Top="66"
                            Content="→" FontSize="13"
                            Click="ButtonMapping_Click" Tag="LStickRight"/>
                    <!-- LStickDown (cx=85.5, cy=110) -->
                    <Button x:Name="BtnLStickDown" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="71.5" Canvas.Top="96"
                            Content="↓" FontSize="13"
                            Click="ButtonMapping_Click" Tag="LStickDown"/>

                    <!-- ============ D-PAD ============ -->
                    <!-- DpadUp (cx=132, cy=103) -->
                    <Button x:Name="BtnDpadUp" Style="{StaticResource CircleButtonStyle}"
                            Width="30" Height="30"
                            Canvas.Left="117" Canvas.Top="88"
                            Content="↑" FontSize="14"
                            Click="ButtonMapping_Click" Tag="DpadUp"/>
                    <!-- DpadLeft (cx=101, cy=133) -->
                    <Button x:Name="BtnDpadLeft" Style="{StaticResource CircleButtonStyle}"
                            Width="30" Height="30"
                            Canvas.Left="86" Canvas.Top="118"
                            Content="←" FontSize="14"
                            Click="ButtonMapping_Click" Tag="DpadLeft"/>
                    <!-- DpadRight (cx=163, cy=133) -->
                    <Button x:Name="BtnDpadRight" Style="{StaticResource CircleButtonStyle}"
                            Width="30" Height="30"
                            Canvas.Left="148" Canvas.Top="118"
                            Content="→" FontSize="14"
                            Click="ButtonMapping_Click" Tag="DpadRight"/>
                    <!-- DpadDown (cx=132, cy=163) -->
                    <Button x:Name="BtnDpadDown" Style="{StaticResource CircleButtonStyle}"
                            Width="30" Height="30"
                            Canvas.Left="117" Canvas.Top="148"
                            Content="↓" FontSize="14"
                            Click="ButtonMapping_Click" Tag="DpadDown"/>

                    <!-- ============ CENTER BUTTONS ============ -->
                    <!-- Minus (cx=143.5, cy=51.5) -->
                    <Button x:Name="BtnMinus" Style="{StaticResource CircleButtonStyle}"
                            Width="32" Height="32"
                            Canvas.Left="127.5" Canvas.Top="35.5"
                            Content="-" FontSize="16" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="Minus"/>
                    <!-- Plus (cx=237.5, cy=51.5) -->
                    <Button x:Name="BtnPlus" Style="{StaticResource CircleButtonStyle}"
                            Width="32" Height="32"
                            Canvas.Left="221.5" Canvas.Top="35.5"
                            Content="+" FontSize="16" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="Plus"/>
                    <!-- Capture (cx=161, cy=80) -->
                    <Button x:Name="BtnCapture" Style="{StaticResource CircleButtonStyle}"
                            Width="32" Height="32"
                            Canvas.Left="145" Canvas.Top="64"
                            Content="📷" FontSize="13"
                            Click="ButtonMapping_Click" Tag="Capture"/>
                    <!-- Home (cx=217.5, cy=80) -->
                    <Button x:Name="BtnHome" Style="{StaticResource CircleButtonStyle}"
                            Width="36" Height="36"
                            Canvas.Left="199.5" Canvas.Top="62"
                            Content="🏠" FontSize="14"
                            Click="ButtonMapping_Click" Tag="Home"/>

                    <!-- ============ ABXY BUTTONS ============ -->
                    <!-- X - top (cx=291, cy=54.5) blue -->
                    <Button x:Name="BtnX" Style="{StaticResource CircleButtonStyle}"
                            Background="#B01E6BC8" BorderBrush="#800066CC"
                            Width="38" Height="38"
                            Canvas.Left="272" Canvas.Top="35.5"
                            Content="X" FontSize="15" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="X"/>
                    <!-- Y - left (cx=261.4, cy=80.2) yellow -->
                    <Button x:Name="BtnY" Style="{StaticResource CircleButtonStyle}"
                            Background="#B0C8A000" BorderBrush="#80FFA500"
                            Width="38" Height="38"
                            Canvas.Left="242.4" Canvas.Top="61.2"
                            Content="Y" FontSize="15" FontWeight="Bold"
                            Foreground="#FFFF00"
                            Click="ButtonMapping_Click" Tag="Y"/>
                    <!-- A - right (cx=320.9, cy=80.2) green -->
                    <Button x:Name="BtnA" Style="{StaticResource CircleButtonStyle}"
                            Background="#B0228B22" BorderBrush="#8032CD32"
                            Width="38" Height="38"
                            Canvas.Left="301.9" Canvas.Top="61.2"
                            Content="A" FontSize="15" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="A"/>
                    <!-- B - bottom (cx=291.2, cy=106) red -->
                    <Button x:Name="BtnB" Style="{StaticResource CircleButtonStyle}"
                            Background="#B08B0000" BorderBrush="#80DC143C"
                            Width="38" Height="38"
                            Canvas.Left="272.2" Canvas.Top="87"
                            Content="B" FontSize="15" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="B"/>

                    <!-- ============ RIGHT STICK ============ -->
                    <!-- RStickUp (cx=240.5, cy=102) -->
                    <Button x:Name="BtnRStickUp" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="226.5" Canvas.Top="88"
                            Content="↑" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickUp"/>
                    <!-- RStickLeft (cx=210, cy=132.7) -->
                    <Button x:Name="BtnRStickLeft" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="196" Canvas.Top="118.7"
                            Content="←" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickLeft"/>
                    <!-- R3 center (cx=240.5, cy=132.7) -->
                    <Button x:Name="BtnRStick" Style="{StaticResource CircleButtonStyle}"
                            Width="46" Height="46"
                            Canvas.Left="217.5" Canvas.Top="109.7"
                            Content="R3" FontSize="12" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="RStick"/>
                    <!-- RStickRight (cx=271, cy=132.7) -->
                    <Button x:Name="BtnRStickRight" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="257" Canvas.Top="118.7"
                            Content="→" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickRight"/>
                    <!-- RStickDown (cx=240.5, cy=163) -->
                    <Button x:Name="BtnRStickDown" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="226.5" Canvas.Top="149"
                            Content="↓" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickDown"/>

                </Canvas>
            </Grid>
        </Viewbox>

        <!-- Status panel -->
        <Border Grid.Row="2" Margin="0,8,0,8" Padding="16,8"
                Background="White" CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtMappingInfo" Text="点击任意按键开始配置"
                           FontSize="14" FontWeight="Bold" Foreground="#1A1A1A"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtCurrentKey" Text=""
                           FontSize="13" Foreground="#666666"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="重置为默认" Width="120" Height="38" Margin="0,0,10,0"
                    Click="ResetButton_Click"
                    Background="#C0392B" Foreground="White" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
            <Button Content="保存配置" Width="120" Height="38" Margin="0,0,10,0"
                    Click="SaveButton_Click"
                    Background="#27AE60" Foreground="White" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
            <Button Content="取消" Width="120" Height="38"
                    Click="CancelButton_Click"
                    Background="#555555" Foreground="White" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
