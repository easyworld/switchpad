                            Click="ButtonMapping_Click" Tag="Y"/>
                    <!-- A - right (cx=320.9, cy=80.2) green -->
                    <Button x:Name="BtnA" Style="{StaticResource CircleButtonStyle}"
                            Background="#B0228B22" BorderBrush="#8032CD32"
                            Width="38" Height="38"
                            Canvas.Left="301.9" Canvas.Top="61.2"
                            Content="A" FontSize="15" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="A"/>
                    <!-- B - bottom (cx=291.2, cy=106) red -->
                    <Button x:Name="BtnB" Style="{StaticResource CircleButtonStyle}"
                            Background="#B08B0000" BorderBrush="#80DC143C"
                            Width="38" Height="38"
                            Canvas.Left="272.2" Canvas.Top="87"
                            Content="B" FontSize="15" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="B"/>

                    <!-- ============ RIGHT STICK ============ -->
                    <!-- RStickUp (cx=240.5, cy=102) -->
                    <Button x:Name="BtnRStickUp" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="226.5" Canvas.Top="88"
                            Content="↑" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickUp"/>
                    <!-- RStickLeft (cx=210, cy=132.7) -->
                    <Button x:Name="BtnRStickLeft" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="196" Canvas.Top="118.7"
                            Content="←" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickLeft"/>
                    <!-- R3 center (cx=240.5, cy=132.7) -->
                    <Button x:Name="BtnRStick" Style="{StaticResource CircleButtonStyle}"
                            Width="38" Height="38"
                            Canvas.Left="221.5" Canvas.Top="113.7"
                            Content="R3" FontSize="12" FontWeight="Bold"
                            Click="ButtonMapping_Click" Tag="RStick"/>
                    <!-- RStickRight (cx=271, cy=132.7) -->
                    <Button x:Name="BtnRStickRight" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="257" Canvas.Top="118.7"
                            Content="→" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickRight"/>
                    <!-- RStickDown (cx=240.5, cy=163) -->
                    <Button x:Name="BtnRStickDown" Style="{StaticResource CircleButtonStyle}"
                            Width="28" Height="28"
                            Canvas.Left="226.5" Canvas.Top="149"
                            Content="↓" FontSize="13"
                            Click="ButtonMapping_Click" Tag="RStickDown"/>

                </Canvas>
            </Grid>
        </Viewbox>

        <!-- Status panel -->
        <Border Grid.Row="2" Margin="0,8,0,8" Padding="16,8"
                Background="White" CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtMappingInfo" Text="点击任意按键开始配置"
                           FontSize="14" FontWeight="Bold" Foreground="#1A1A1A"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtCurrentKey" Text=""
                           FontSize="13" Foreground="#666666"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="重置为默认" Width="120" Height="38" Margin="0,0,10,0"
                    Click="ResetButton_Click"
                    Background="#C0392B" Foreground="White" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
            <Button Content="保存配置" Width="120" Height="38" Margin="0,0,10,0"
                    Click="SaveButton_Click"
                    Background="#27AE60" Foreground="White" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
            <Button Content="取消" Width="120" Height="38"
                    Click="CancelButton_Click"
                    Background="#555555" Foreground="White" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
