<Window x:Class="SwitchPad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SwitchPad - NS2 Remote Control" Height="600" Width="1000"
        MinHeight="400" MinWidth="800"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video Display Area -->
        <Border Grid.Row="0" Background="Black" Margin="10">
            <Viewbox Stretch="Uniform">
                <Image x:Name="VideoImage" Width="1920" Height="1080" Stretch="Uniform"/>
            </Viewbox>
        </Border>

        <!-- Control Panel -->
        <Grid x:Name="ControlPanel" Grid.Row="1" Background="#F0F0F0" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Serial Port Config -->
            <StackPanel Grid.Column="0" Margin="10">
                <TextBlock Text="串口设备" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="SerialPortComboBox" Height="30" Margin="0,0,0,5"/>
                <Button x:Name="ConnectButton" Content="连接" Height="30" Click="ConnectButton_Click" Focusable="False"/>
                <TextBlock x:Name="SerialStatusText" Text="未连接" Margin="0,5,0,0" Foreground="Red"/>
            </StackPanel>

            <!-- Video Source Config -->
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="视频采集源" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="VideoSourceComboBox" Height="30" Margin="0,0,0,5"/>
                <Button x:Name="VideoSourceButton" Content="切换采集源" Height="30" Click="VideoSourceButton_Click" Focusable="False"/>
                <TextBlock x:Name="VideoStatusText" Text="未连接" Margin="0,5,0,0" Foreground="Red"/>
            </StackPanel>

            <!-- Audio Device Config -->
            <StackPanel Grid.Column="2" Margin="10">
                <TextBlock Text="音频设备" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="AudioDeviceComboBox" Height="30" Margin="0,0,0,5"/>
                <Button x:Name="AudioStartButton" Content="启动音频" Height="30" Click="AudioStartButton_Click" Focusable="False"/>
                <TextBlock x:Name="AudioStatusText" Text="音频未启动" Margin="0,5,0,0" Foreground="Red"/>
            </StackPanel>

            <!-- Button Mapping Config -->
            <StackPanel Grid.Column="3" Margin="10">
                <TextBlock Text="按键配置" FontWeight="Bold" Margin="0,0,0,5"/>
                <Button x:Name="KeyMappingButton" Content="自定义按键映射" Height="30" Click="KeyMappingButton_Click" Margin="0,0,0,5" Focusable="False"/>
                <Button x:Name="ReloadConfigButton" Content="重新加载配置" Height="30" Click="ReloadConfigButton_Click" Focusable="False"/>
            </StackPanel>

            <!-- NS2 Wakeup -->
            <StackPanel Grid.Column="4" Margin="10">
                <TextBlock Text="设备唤醒" FontWeight="Bold" Margin="0,0,0,5"/>
                <Button x:Name="WakeupButton" Content="唤醒 NS2" Height="30" Click="WakeupButton_Click" Margin="0,0,0,5" Focusable="False"/>
                <Grid>
                    <TextBox x:Name="WakeupCidrTextBox" Height="26" FontSize="11" Padding="4,3"/>
                    <TextBlock Text="例如：192.168.3.0/24" IsHitTestVisible="False"
                               Foreground="#AAAAAA" FontSize="11" Padding="6,0,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=WakeupCidrTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <TextBlock x:Name="WakeupStatusText" Text="" Margin="0,5,0,0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
